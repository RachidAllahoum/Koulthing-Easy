-- =============================================================================
-- product-images bucket + RLS (storage.objects)
-- Paths must be: {auth.uid()}/...  (first folder = signed-in user's id)
-- =============================================================================

-- 1) Public bucket (id and name are both 'product-images' in Supabase)
INSERT INTO storage.buckets (id, name, public, file_size_limit, allowed_mime_types)
VALUES (
  'product-images',
  'product-images',
  true,
  NULL,  -- optional: e.g. 10485760 for 10 MB cap at bucket level
  NULL   -- optional: e.g. ARRAY['image/jpeg','image/png','image/webp','image/gif']
)
ON CONFLICT (id) DO UPDATE SET
  public = EXCLUDED.public;

-- 2) Public read (anyone can SELECT / get public URL for this bucket)
DROP POLICY IF EXISTS "product_images_select_public" ON storage.objects;
CREATE POLICY "product_images_select_public"
  ON storage.objects
  FOR SELECT
  TO public
  USING (bucket_id = 'product-images');

-- 3) Authenticated users: insert only under their own uid prefix
DROP POLICY IF EXISTS "product_images_insert_own" ON storage.objects;
CREATE POLICY "product_images_insert_own"
  ON storage.objects
  FOR INSERT
  TO authenticated
  WITH CHECK (
    bucket_id = 'product-images'
    AND split_part(name, '/', 1) = auth.uid()::text
  );

-- 4) Authenticated users: update only their own objects
DROP POLICY IF EXISTS "product_images_update_own" ON storage.objects;
CREATE POLICY "product_images_update_own"
  ON storage.objects
  FOR UPDATE
  TO authenticated
  USING (
    bucket_id = 'product-images'
    AND split_part(name, '/', 1) = auth.uid()::text
  );

-- 5) Authenticated users: delete only their own objects
DROP POLICY IF EXISTS "product_images_delete_own" ON storage.objects;
CREATE POLICY "product_images_delete_own"
  ON storage.objects
  FOR DELETE
  TO authenticated
  USING (
    bucket_id = 'product-images'
    AND split_part(name, '/', 1) = auth.uid()::text
  );